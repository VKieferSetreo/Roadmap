# Roadmap-Backend — Konfiguration (Kopie als server/.env, wird von index.js/migrate/seed geladen)

PORT=8095
DATABASE_URL=postgres://roadmap:roadmap@localhost:5432/roadmap

# Gateway-Auth (setreo-proxy setzt X-Auth-User / X-Auth-Roles).
# false = Dev-Modus: ohne Header wird ein anonymer Dev-User mit Admin-Rechten angenommen.
REQUIRE_AUTH=false

# Externe Provider (nur serverseitig, immer mit Timeout + DB-Cache + Fallback).
# T-338: NUR self-hosted Endpunkte eintragen. LEER = Dienst deaktiviert (KEIN stiller Fallback
# auf öffentliche OSM/OSRM-Endpunkte — Adress-/Routendaten dürfen nicht zu Dritten lecken).
# Ohne OSRM_URL → deterministischer Geometrie-Fallback; ohne NOMINATIM_URL → Städte-Tabelle.
NOMINATIM_URL=
OSRM_URL=http://osrm:5000
EXTERNAL_TIMEOUT_MS=4000

# Korridor-Breite des Hindernis-Matchings in Metern
CORRIDOR_M=120

# Share-Links (v2): Basis-URL der öffentlichen Links + Salt für Unlock-Tokens.
# SESSION_SALT in Prod auf einen zufälligen Wert setzen (z.B. openssl rand -hex 32).
SHARE_BASE_URL=https://setreo-cloud.com
SESSION_SALT=change-me

# Import-Worker (v3, eigener Prozess: npm run worker / Dockerfile.worker).
# CONNECTORS = CSV der aktiven quelleIds (siehe Quellen-Register, migrations/003).
# Leer/ungesetzt = Worker läuft im Leerlauf (nur Heartbeat) — Default, bis Datenformat final.
CONNECTORS=
# Roads für den Autobahn-Connector (Quelle 0001)
AUTOBAHN_ROADS=A1,A2,A3,A5,A7,A8,A9,A24

# E-Mail-Versand (Mailjet v3.1 Send-API) — WIRD VON API (Passwort-Reset) UND WORKER
# (Fund-Benachrichtigungen) GENUTZT. Beide Prozesse brauchen identische Werte (T-474/T-475):
# ein abweichender MAILJET_FROM_EMAIL bricht DKIM und der Worker sendet sonst still nichts.
# Ohne MAILJET_ENABLED=true ist der Versand ein No-op (App läuft normal, nur keine Mails).
MAILJET_ENABLED=false
MAILJET_API_KEY=
MAILJET_API_SECRET=
# Verifizierter Absender mit DKIM/SPF — in Prod EINHEITLICH (api == worker) setzen.
MAILJET_FROM_EMAIL=noreply@setreo-intern.com
MAILJET_FROM_NAME=Setreo Roadmap
# Öffentliche Basis-URL für Links in Benachrichtigungsmails.
PUBLIC_ROADMAP_URL=https://setreo-cloud.com/roadmap

# Error-Tracking (self-hosted GlitchTip, Sentry-kompatibel). Leer = aus (Tests/lokal).
SENTRY_DSN=
