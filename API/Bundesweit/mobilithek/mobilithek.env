# Mobilithek (NAP DE) — Zugang
# ACCOUNT ANLEGEN: https://mobilithek.info/   (Konto -> Datensatz abonnieren -> Zertifikat)
# Authentifizierung erfolgt i.d.R. per Client-Zertifikat (mTLS), nicht per simplem API-Key.
# Pro abonniertem Datensatz wird eine eigene Broker-Feed-URL im Konto sichtbar -> hier eintragen.
MOBILITHEK_FEED_URL=
MOBILITHEK_CERT=
MOBILITHEK_CERT_KEY=
MOBILITHEK_CERT_PASS=
