ocoding/Level/state"}, {"key": "politicalGeocodingURI", "value": "http://dcat-ap.de/def/politicalGeocoding/stateKey/05"}, {"key": "publisher_email", "value": "Schwertransporte@strassen.nrw.de"}, {"key": "publisher_name", "value": "Landesbetrieb Stra\u00dfenbau Nordrhein-Westfalen"}, {"key": "publisher_tel", "value": "+49 209 3808-287"}, {"key": "publisher_url", "value": "https://www.strassen.nrw.de/de/partner/grossraum-und-schwertransporte.html"}, {"key": "harvest_object_id", "value": "8d56f72e-944a-400a-ac61-8ef545c6b405"}, {"key": "harvest_source_id", "value": "a1583a43-8015-4a67-8424-04ee1cd29470"}, {"key": "harvest_source_title", "value": "Open.NRW Redesign Formular-Harvester"}], "groups": [{"description": "", "display_name": "Verkehr", "id": "7d26daac-9818-430e-98a5-825a3a9d4afa", "image_display_url": "", "name": "tran", "title": "Verkehr"}], "resources": [{"cache_last_updated": null, "cache_url": null, "created": "2026-05-27T12:30:53.814997", "description": "Die Zugangs URL f\u00fchrt auf die digitale Karte (GIScloud.NRW) ", "format": "http://publications.europa.eu/resource/authority/file-type/HTML", "format_new": "http://publications.europa.eu/resource/authority/file-type/HTML", "format_orig": "html", "hash": "", "id": "74af9d20-e14d-4404-82f3-bf94c08d02cf", "last_modified": null, "license": "http://dcat-ap.de/def/licenses/other-open", "license_infos": "Andere offene Lizenz;unbekannt", "metadata_modified": "2026-05-27T12:30:53.802571", "mimetype": "https://www.iana.org/assignments/media-types/text/html", "mimetype_inner": null, "modified": "2022-05-31", "package_id": "f9864b85-d87a-4812-9162-eda819b40822", "position": 0, "resource_type": null, "size": null, "state": "active", "url": "https://www.giscloud.nrw.de/arcgis/apps/webappviewer/index.html?id=35c61ce20f2c4639a333be830891e207", "url_type": null}], "tags": [{"display_name": " Ausnahmegenehmigung", "id": "44140cda-2fc2-4c8c-b71e-7ab46a059f24", "name": " Ausnahmegenehmigung", "state": "active", "vocabulary_id": null}, {"display_name": " Bauwerke", "id": "42cd283b-92cb-4e3a-8a15-b21ea0c65ec8", "name": " Bauwerke", "state": "active", "vocabulary_id": null}, {"display_name": " Br\u00fccken", "id": "2e5a9ccd-4cfe-431d-834a-6bb05c882434", "name": " Br\u00fccken", "state": "active", "vocabulary_id": null}, {"display_name": " Karte", "id": "1b416dfd-8c0f-4c59-afc9-d7082b44bfde", "name": " Karte", "state": "active", "vocabulary_id": null}, {"display_name": " StVO", "id": "50219353-df85-439e-ab70-53ee407b3af3", "name": " StVO", "state": "active", "vocabulary_id": null}, {"display_name": " StVZO", "id": "7f3321ba-30d0-4f2b-93e5-ce81c4e50592", "name": " StVZO", "state": "active", "vocabulary_id": null}, {"display_name": " lastbeschr\u00e4nkt", "id": "b4a612b1-2736-4b5a-b6d6-316624bfa8e5", "name": " lastbeschr\u00e4nkt", "state": "active", "vocabulary_id": null}, {"display_name": "Stra\u00dfenverkehr Schwertransport", "id": "1dc65e33-9171-48e9-973f-9d60c1610101", "name": "Stra\u00dfenverkehr Schwertransport", "state": "active", "vocabulary_id": null}], "relationships_as_subject": [], "relationships_as_object": []}, {"creator_user_id": "e2600eb3-f6f4-48e1-82db-a014dc21ec31", "id": "97faa68d-e57f-4010-a6df-0b520c4c3d67", "isopen": false, "license_id": "http://dcat-ap.de/def/licenses/other-open", "license_title": "Andere offene Lizenz", "maintainer": "Landesbetrieb Stra\u00dfenbau Nordrhein-Westfalen", "maintainer_email": "schwertransporte@strassen.nrw.de", "metadata_created": "2026-05-27T12:28:16.978848", "metadata_modified": "2026-05-27T12:28:16.978854", "name": "dauererlaubnisse_f__r_autokrane_in_nrw___schwertransportkarte_f__r_den_36_t_auto_kopie_16539905", "notes": "Die digitale Schwertransportkarte stellt s\u00e4mtliche Bauwerke in der Baulast des Landesbetriebes Stra\u00dfenbau NRW und der Autobahn GmbH dar, die aus statischer Sicht nicht passiert werden d\u00fcrfen. \r\nDie Karte dient lediglich als \u00dcbersicht f\u00fcr die Planung und Durchf\u00fchrung der Transporte. Sie ersetzt nicht die Beantragung der Erlaubnis / Genehmigung!\r\nGem\u00e4\u00df NRW-Erlass 58.97.02.04-000002 vom 19.01.2021 kann f\u00fcr bestimmte Autokrane mit 4 Achsen und einem Gesamtgewicht von 48 t eine fl\u00e4chendeckende Dauererlaubnis f\u00fcr Bundesfern- und Landesstra\u00dfen in NRW ohne Anh\u00f6rung des Landesbetriebes Stra\u00dfenbau NRW erteilt werden. Voraussetzung hierf\u00fcr ist das Einholen der aktuellen digitalen Schwertransportkarte des Landesbetriebes Stra\u00dfenbau NRW. Unmittelbar vor Fahrtbeginn ist die entsprechende tagesaktuelle digitale Schwertransportkarte durch den Fahrer bzw. die Fahrerin abzurufen und der vorgesehene Fahrweg hinsichtlich vorhandener Bauwerke mit Fahrverboten zu pr\u00fcfen.\r\nDarunter fallen ausschlie\u00dflich folgende Krane: vierachsige Autokrane mit einem Achsabstand von min. 1,65 m und einem Abstand zwischen erster und vierter Achse von mindestens 5,30 m fl\u00e4chendeckend f\u00fcr das Befahren von Bundesfernstra\u00dfen.\r\nAktuell wird die Bereitstellung der zugrundeliegenden Rohdaten gepr\u00fcft. Bei Interesse an einer zuk\u00fcnftigen Nachnutzung der Rohdaten k\u00f6nnen Sie sich an die angegebene E-Mailadresse im Feld \"Kontakt aufnehmen\" wenden. Wichtiger Hinweis: Bitte beachten Sie f\u00fcr die derzeitige Lizenzregelung die auf der externen Kartenansicht gemachten Angaben zu Nutzungsbedingungen sowie die Datenschutzhinweise.", "num_resources": 1, "num_tags": 7, "organization": {"id": "0f6d64fb-87d2-4520-94af-df1ea57c64c7", "name": "landesbehoerden", "title": "Landesbeh\u00f6rden", "type": "organization", "description": "", "image_url": "", "created": "2023-01-17T09:40:16.432539", "is_organization": true, "approval_status": "approved", "state": "active"}, "owner_org": "0f6d64fb-87d2-4520-94af-df1ea57c64c7", "private": false, "state": "active", "title": "Dauererlaubnisse f\u00fcr Autokrane in NRW - Schwertransportkarte f\u00fcr den 48 t Autokran", "type": "dataset", "extras": [{"key": "contributorID"